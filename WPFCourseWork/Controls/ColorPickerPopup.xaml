<Popup x:Class="WPFCourseWork.Controls.ColorPickerPopup"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       AllowsTransparency="True"
       StaysOpen="False"
       Placement="Bottom"
       PopupAnimation="Fade">
    <Border Background="White"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            Padding="8"
            CornerRadius="4">
        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>

                <Canvas x:Name="SaturationValueCanvas"
                        Grid.Column="0"
                        Width="180"
                        Height="140"
                        Background="Black"
                        Cursor="Cross"
                        MouseLeftButtonDown="OnSaturationValueMouseDown"
                        MouseMove="OnSaturationValueMouseMove"
                        MouseLeftButtonUp="OnSaturationValueMouseUp">
                    <Image x:Name="SaturationValueImage"
                           Width="180"
                           Height="140"
                           Stretch="Fill"/>
                    <Ellipse x:Name="SaturationValueMarker"
                             Width="10"
                             Height="10"
                             Stroke="White"
                             StrokeThickness="1.5"
                             Fill="Transparent"
                             IsHitTestVisible="False"/>
                </Canvas>

                <Canvas x:Name="HueCanvas"
                        Grid.Column="2"
                        Width="20"
                        Height="140"
                        Cursor="Cross"
                        MouseLeftButtonDown="OnHueMouseDown"
                        MouseMove="OnHueMouseMove"
                        MouseLeftButtonUp="OnHueMouseUp">
                    <Image x:Name="HueImage"
                           Width="20"
                           Height="140"
                           Stretch="Fill"/>
                    <Rectangle x:Name="HueMarker"
                               Width="24"
                               Height="3"
                               Fill="White"
                               Stroke="#333333"
                               StrokeThickness="1"
                               Margin="-2,0,0,0"
                               IsHitTestVisible="False"/>
                </Canvas>
            </Grid>

            <StackPanel Orientation="Horizontal"
                        Margin="0,8,0,0"
                        VerticalAlignment="Center">
                <Border x:Name="PreviewSwatch"
                        Width="24"
                        Height="24"
                        BorderBrush="#888888"
                        BorderThickness="1"
                        Margin="0,0,8,0"/>
                <TextBlock x:Name="PreviewHexText"
                           VerticalAlignment="Center"
                           FontFamily="Consolas"
                           FontSize="12"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Popup>
