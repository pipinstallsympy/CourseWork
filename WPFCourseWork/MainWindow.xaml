<Window x:Class="WPFCourseWork.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
        xmlns:controls="clr-namespace:WPFCourseWork.Controls"
        mc:Ignorable="d"
        Title="Course Work Zherbin" Height="540" Width="960" WindowStyle="ThreeDBorderWindow">
    <Grid Name="MainRoot" Background="White">
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width = "*"></ColumnDefinition>
            <ColumnDefinition Width = "280"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height = "*"></RowDefinition>
            <RowDefinition Height = "Auto"></RowDefinition>
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Name="Space3D">
            <Border BorderBrush="Black" BorderThickness="1"></Border>
            <hx:Viewport3DX x:Name="Viewport"
                           CameraMode="Inspect"
                           ZoomExtentsWhenLoaded="False"
                           ShowCoordinateSystem="False"
                           ShowViewCube="False"
                           CoordinateSystemHorizontalPosition="0.82"
                           CoordinateSystemVerticalPosition="-0.82"
                           CoordinateSystemSize="120" />

            <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Margin="10" Padding="10,8"
                    Background="#CCFFFFFF" BorderBrush="Black" BorderThickness="1"
                    CornerRadius="4">
                <StackPanel>
                    <TextBlock x:Name="StatsMaterialCount"   Text="Узлов материала: -"/>
                    <TextBlock x:Name="StatsPoreCount"       Text="Узлов пор: -"/>
                    <TextBlock x:Name="StatsCoherencyCount"  Text="Связных компонент: -"/>
                    <TextBlock x:Name="StatsPercolationCount" Text="Деревьев перколяции: -"/>
                    <TextBlock x:Name="StatsLastCalcTime"    Text="Время последнего расчёта: -"/>
                </StackPanel>
            </Border>

        </Grid>
        
        <TabControl x:Name="MainSideTabControl"
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="10"
                    SelectionChanged="OnMainSideTabChanged">
            <TabItem x:Name="ObjectTabItem" Header="Объект">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                            <TextBlock>
                                Выберите метод:
                            </TextBlock>
                        
                            <StackPanel>
                                <ComboBox x:Name = "MethodsPanel" SelectedIndex="0">
                                    <ComboBoxItem>"Единичный куб"</ComboBoxItem>
                                    <ComboBoxItem>"Заданный куб"</ComboBoxItem>
                                    <ComboBoxItem>"Куб, заданный двумя точками"</ComboBoxItem>
                                </ComboBox>
                                
                                <StackPanel x:Name = "MethodsValue2" Visibility="Collapsed">
                                    <Rectangle Height="5"/>
                                    
                                    <TextBlock> Координаты центровой точки</TextBlock>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Margin="0,0,4,0">x:</TextBlock>
                                        <TextBox x:Name = "CenterX" Width="50"></TextBox>
                                        <Rectangle Height = "5" Width = "36"></Rectangle> 
                                        
                                        <TextBlock Margin="0,0,4,0">y:</TextBlock>
                                        <TextBox x:Name = "CenterY" Width="50"></TextBox>
                                        <Rectangle Height = "5" Width = "37"></Rectangle> 
                                        
                                        <TextBlock>z:</TextBlock>
                                        <TextBox x:Name = "CenterZ" Width="50"></TextBox>
                                    </StackPanel>

                                    <Rectangle Height="10"/>
                                    
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Margin="0,0,4,0">Длина стороны куба: </TextBlock>
                                        <TextBox x:Name = "CubeSideLength" Width="136"></TextBox>
                                    </StackPanel>
                                </StackPanel>
                                
                                <StackPanel x:Name = "MethodsValue3" Visibility="Collapsed">
                                    <Rectangle Height="5"/>
                                    
                                    <TextBlock> Координаты первой точки</TextBlock>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Margin="0,0,4,0">x:</TextBlock>
                                        <TextBox x:Name = "P1X" Width="50"></TextBox>
                                        <Rectangle Height = "5" Width = "36"></Rectangle> 
                                        
                                        <TextBlock Margin="0,0,4,0">y:</TextBlock>
                                        <TextBox x:Name = "P1Y" Width="50"></TextBox>
                                        <Rectangle Height = "5" Width = "37"></Rectangle> 
                                        
                                        <TextBlock>z:</TextBlock>
                                        <TextBox x:Name = "P1Z" Width="50"></TextBox>
                                    </StackPanel>

                                    <Rectangle Height="5"/>
                                    
                                    <TextBlock> Координаты второй точки</TextBlock>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Margin="0,0,4,0">x:</TextBlock>
                                        <TextBox x:Name = "P2X" Width="50"></TextBox>
                                        <Rectangle Height = "5" Width = "36"></Rectangle> 
                                        
                                        <TextBlock Margin="0,0,4,0">y:</TextBlock>
                                        <TextBox x:Name = "P2Y" Width="50"></TextBox>
                                        <Rectangle Height = "5" Width = "37"></Rectangle> 
                                        
                                        <TextBlock>z:</TextBlock>
                                        <TextBox x:Name = "P2Z" Width="50"></TextBox>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            
                            <Rectangle Height="15"/>
                            
                            <StackPanel Orientation="Horizontal">
                                <TextBlock>
                                    Введите кол-во разбиений:
                                </TextBlock>
                                <TextBox x:Name = "PartitionAmount" Width="100" Margin="5, 0, 0, 0">
                                </TextBox>
                            </StackPanel>

                            <Rectangle Height="15"/>

                            <StackPanel x:Name = "PorePanel" >
                                <TextBlock>Вид распределение пор:</TextBlock>
                                <RadioButton GroupName="Pores" Content="По количеству" IsChecked="True" />
                                <RadioButton GroupName="Pores" Content="По процентному соотношению" />
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal">
                                <TextBlock>
                                    Значение:
                                </TextBlock>
                                <TextBox x:Name = "PoresValue" Width="196" Margin="5, 0, 0, 0">
                                </TextBox>
                            </StackPanel>

                            <Rectangle Height="10"/>

                            <CheckBox x:Name="ColorComponentsCheckBox"
                                      Checked="OnColorByComponentChanged"
                                      Unchecked="OnColorByComponentChanged"
                                      HorizontalContentAlignment="Left">
                                <TextBlock Text="Показывать связные участки разными цветами"
                                           TextWrapping="Wrap"
                                           MaxWidth="230"/>
                            </CheckBox>

                            <Rectangle Height="5"/>

                            <CheckBox x:Name="PreserveMaterialCheckBox"
                                      HorizontalContentAlignment="Left">
                                <TextBlock Text="Сохранять количество материала при соединении"
                                           TextWrapping="Wrap"
                                           MaxWidth="230"/>
                            </CheckBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="PercolationTabItem" Header="Перколяция" IsEnabled="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="Дерево перколяции:"/>
                    <ComboBox x:Name="PercolationTreeSelector"
                              Margin="0,4,0,0"
                              SelectionChanged="OnPercolationTreeSelectionChanged"/>

                    <TextBlock Text="Кликните по поре на границе образца, чтобы подсветить её связи."
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="Gray"/>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Rectangle Grid.Row="0" Grid.Column="0" Width="12" Height="12" Fill="LimeGreen" Margin="0,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="пограничная / выбранная" FontSize="11" Margin="0,0,0,4"/>
                        <Rectangle Grid.Row="1" Grid.Column="0" Width="12" Height="12" Fill="DarkSeaGreen" Margin="0,0,4,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="внутренняя" FontSize="11" Margin="0,0,0,4"/>
                        <Rectangle Grid.Row="2" Grid.Column="0" Width="12" Height="12" Fill="DodgerBlue" Margin="0,0,4,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="сквозная связь" FontSize="11" Margin="0,0,0,4"/>
                        <Rectangle Grid.Row="3" Grid.Column="0" Width="12" Height="12" Fill="Gold" Margin="0,0,4,4"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="частичная связь" FontSize="11" Margin="0,0,0,4"/>
                        <Rectangle Grid.Row="4" Grid.Column="0" Width="12" Height="12" Fill="LightGray" Margin="0,0,4,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="прочие (при выборе)" FontSize="11"/>
                    </Grid>

                    <Rectangle Height="10"/>

                    <RadioButton x:Name="ShowFullPercolationTreeRadio"
                                 Content="Показать всё дерево"
                                 IsChecked="True"
                                 Margin="0,4,0,0"
                                 Checked="OnPercolationDisplayModeChanged"
                                 Unchecked="OnPercolationDisplayModeChanged"/>
                    <RadioButton x:Name="ShowBoundaryPercolationPoresRadio"
                                 Content="Только пограничные поры"
                                 Margin="0,4,0,0"
                                 Checked="OnPercolationDisplayModeChanged"
                                 Unchecked="OnPercolationDisplayModeChanged"/>

                    <Rectangle Height="15"/>

                    <TextBlock x:Name="PercolationStatsPoreCount" Text="Кол-во пор: -"/>
                    <TextBlock x:Name="PercolationStatsBoundaryPores" Text="Кол-во пограничных пор: -" Margin="0,4,0,0"/>
                    <TextBlock x:Name="PercolationStatsEndToEnd" Text="Пар сквозной перколяции: -" Margin="0,4,0,0"/>
                    <TextBlock x:Name="PercolationStatsPartial" Text="Пар частичной перколяции: -" Margin="0,4,0,0"/>
                    <TextBlock x:Name="PercolationStatsHasThrough" Text="Сквозная перколяция: -" Margin="0,4,0,0"/>
                    <TextBlock x:Name="PercolationStatsTreeDepth" Text="Глубина октодерева: -" Margin="0,4,0,0"/>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="FileTabItem" Header="Файл">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Экспорт в файл Wavefront OBJ."
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="Что сохранять:"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"/>

                        <RadioButton x:Name="ExportMaterialOnlyRadio"
                                     Content="Только материал"
                                     IsChecked="True"
                                     Margin="0,8,0,0"
                                     Checked="OnExportModeChanged"
                                     Unchecked="OnExportModeChanged"/>
                        <RadioButton x:Name="ExportPoresOnlyRadio"
                                     Content="Только поры"
                                     Margin="0,4,0,0"
                                     Checked="OnExportModeChanged"
                                     Unchecked="OnExportModeChanged"/>
                        <RadioButton x:Name="ExportCombinedRadio"
                                     Content="Материал и поры (разные цвета)"
                                     Margin="0,4,0,0"
                                     Checked="OnExportModeChanged"
                                     Unchecked="OnExportModeChanged"/>

                        <CheckBox x:Name="ExportWithColorCheckBox"
                                  Content="Экспортировать с цветом"
                                  IsChecked="True"
                                  Margin="0,12,0,0"
                                  Checked="OnExportColorOptionChanged"
                                  Unchecked="OnExportColorOptionChanged"/>

                        <StackPanel x:Name="ExportMaterialColorRow"
                                    Orientation="Horizontal"
                                    Margin="0,8,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                            <TextBlock Text="Материал:"
                                       Width="72"
                                       VerticalAlignment="Center"/>
                            <Border x:Name="ExportMaterialColorSwatch"
                                    Width="20"
                                    Height="20"
                                    BorderBrush="Gray"
                                    BorderThickness="1"
                                    Background="#CC2222"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="OnExportMaterialColorSwatchClick"/>
                            <TextBox x:Name="ExportMaterialColorHex"
                                     Width="72"
                                     Margin="8,0,0,0"
                                     FontFamily="Consolas"
                                     Text="#CC2222"
                                     LostFocus="OnExportMaterialColorHexLostFocus"
                                     KeyDown="OnExportColorHexKeyDown"/>
                        </StackPanel>

                        <StackPanel x:Name="ExportPoreColorRow"
                                    Orientation="Horizontal"
                                    Margin="0,6,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                            <TextBlock Text="Поры:"
                                       Width="72"
                                       VerticalAlignment="Center"/>
                            <Border x:Name="ExportPoreColorSwatch"
                                    Width="20"
                                    Height="20"
                                    BorderBrush="Gray"
                                    BorderThickness="1"
                                    Background="#8FBC8F"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="OnExportPoreColorSwatchClick"/>
                            <TextBox x:Name="ExportPoreColorHex"
                                     Width="72"
                                     Margin="8,0,0,0"
                                     FontFamily="Consolas"
                                     Text="#8FBC8F"
                                     LostFocus="OnExportPoreColorHexLostFocus"
                                     KeyDown="OnExportColorHexKeyDown"/>
                        </StackPanel>

                        <controls:ColorPickerPopup x:Name="ExportColorPickerPopup"
                                                   ColorChanged="OnExportColorPickerColorChanged"/>

                        <TextBlock x:Name="ExportModeHintText"
                                   Text="Сохраняются только воксели материала (без пор)."
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="Gray"/>

                        <TextBlock Text="Blender: импортируйте только .obj (не .mtl). Файл .mtl — рядом с .obj."
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="Gray"/>

                        <Button x:Name="SaveObjButton"
                                Content="Сохранить в OBJ..."
                                Margin="0,12,0,0"
                                Height="30"
                                Click="OnSaveObj"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="LogsTabItem" Header="Логи">
                <TextBox x:Name="LogsTextBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         FontFamily="Consolas"
                         FontSize="11"
                         Background="#FAFAFA"
                         BorderThickness="0"/>
            </TabItem>
        </TabControl>

        <Grid Grid.Column="1"
              Grid.Row="1"
              Margin="10,0,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="CalculationProgressPanel"
                        Grid.Row="0"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Margin="5,0,5,8"
                        Visibility="Collapsed">
                <TextBlock x:Name="CalculationProgressText"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,0,0,4"/>
                <ProgressBar x:Name="CalculationProgressBar"
                             Height="14"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             Foreground="LimeGreen"/>
            </StackPanel>

            <Button Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Content="Сгенерировать объект"
                    Click="OnMethodSelected"
                    Margin="5"
                    Height="30"
                    VerticalAlignment="Bottom"/>

            <Button Grid.Row="2"
                    Grid.Column="0"
                    x:Name="ConnectComponentsButton"
                    Content="Соединить компоненты"
                    Click="OnConnectComponents"
                    Margin="5"
                    Height="30"
                    VerticalAlignment="Bottom"/>

            <Button Grid.Row="2"
                    Grid.Column="1"
                    x:Name="CheckPercolationButton"
                    Content="Проверка на перколяцию"
                    Click="OnCheckPercolation"
                    Margin="5"
                    Height="30"
                    VerticalAlignment="Bottom"/>
        </Grid>
    </Grid>
</Window>
