<Window x:Class="WPFCourseWork.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
        mc:Ignorable="d"
        Title="Course Work Zherbin" Height="540" Width="960" WindowStyle="ThreeDBorderWindow">
    <Grid Name="MainRoot" Background="White">
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width = "*"></ColumnDefinition>
            <ColumnDefinition Width = "280"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height = "*"></RowDefinition>
            <RowDefinition Height = "Auto"></RowDefinition>
        </Grid.RowDefinitions>
        
        
        
        
        <Grid Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Name="Space3D">
            <Border BorderBrush="Black" BorderThickness="1"></Border>
            <hx:Viewport3DX x:Name="Viewport"
                           CameraMode="Inspect"
                           ZoomExtentsWhenLoaded="False"
                           ShowCoordinateSystem="True"
                           ShowViewCube="False"
                           CoordinateSystemHorizontalPosition="0.82"
                           CoordinateSystemVerticalPosition="-0.82"
                           CoordinateSystemSize="120" />

            <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Margin="10" Padding="10,8"
                    Background="#CCFFFFFF" BorderBrush="Black" BorderThickness="1"
                    CornerRadius="4">
                <StackPanel>
                    <TextBlock x:Name="StatsMaterialCount"   Text="Узлов материала: -"/>
                    <TextBlock x:Name="StatsPoreCount"       Text="Узлов пор: -"/>
                    <TextBlock x:Name="StatsCoherencyCount"  Text="Связных компонент: -"/>
                    <TextBlock x:Name="StatsPercolationCount" Text="Деревьев перколяции: -"/>
                    <TextBlock x:Name="StatsLastCalcTime"    Text="Время последнего расчёта: -"/>
                </StackPanel>
            </Border>

        </Grid>
        
        
        <Grid Grid.Row = "0" Grid.Column = "1" >
            <StackPanel Margin="10">
                <TextBlock>
                    Выберите метод:
                </TextBlock>
            
                <StackPanel>
                    <ComboBox x:Name = "MethodsPanel" SelectedIndex="0">
                        <ComboBoxItem>"Единичный куб"</ComboBoxItem>
                        <ComboBoxItem>"Заданный куб"</ComboBoxItem>
                        <ComboBoxItem>"Куб, заданный двумя точками"</ComboBoxItem>
                    </ComboBox>
                    
                    <StackPanel x:Name = "MethodsValue2" Visibility="Collapsed">
                        <Rectangle Height="5"/> <!-- Разделитель между элементами -->
                        
                        <TextBlock> Координаты центровой точки</TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,4,0">x:</TextBlock>
                            <TextBox x:Name = "CenterX" Width="50"></TextBox>
                            <Rectangle Height = "5" Width = "36"></Rectangle> 
                            
                            <TextBlock Margin="0,0,4,0">y:</TextBlock>
                            <TextBox x:Name = "CenterY" Width="50"></TextBox>
                            <Rectangle Height = "5" Width = "37"></Rectangle> 
                            
                            <TextBlock>z:</TextBlock>
                            <TextBox x:Name = "CenterZ" Width="50"></TextBox>
                        </StackPanel>

                        <Rectangle Height="10"/> <!-- Разделитель между элементами -->
                        
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,4,0">Длина стороны куба: </TextBlock>
                            <TextBox x:Name = "CubeSideLength" Width="136"></TextBox>
                        </StackPanel>
                    </StackPanel>
                    
                    <StackPanel x:Name = "MethodsValue3" Visibility="Collapsed">
                        <Rectangle Height="5"/> <!-- Разделитель между элементами -->
                        
                        <TextBlock> Координаты первой точки</TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,4,0">x:</TextBlock>
                            <TextBox x:Name = "P1X" Width="50"></TextBox>
                            <Rectangle Height = "5" Width = "36"></Rectangle> 
                            
                            <TextBlock Margin="0,0,4,0">y:</TextBlock>
                            <TextBox x:Name = "P1Y" Width="50"></TextBox>
                            <Rectangle Height = "5" Width = "37"></Rectangle> 
                            
                            <TextBlock>z:</TextBlock>
                            <TextBox x:Name = "P1Z" Width="50"></TextBox>
                        </StackPanel>

                        <Rectangle Height="5"/> <!-- Разделитель между элементами -->
                        
                        <TextBlock> Координаты второй точки</TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,4,0">x:</TextBlock>
                            <TextBox x:Name = "P2X" Width="50"></TextBox>
                            <Rectangle Height = "5" Width = "36"></Rectangle> 
                            
                            <TextBlock Margin="0,0,4,0">y:</TextBlock>
                            <TextBox x:Name = "P2Y" Width="50"></TextBox>
                            <Rectangle Height = "5" Width = "37"></Rectangle> 
                            
                            <TextBlock>z:</TextBlock>
                            <TextBox x:Name = "P2Z" Width="50"></TextBox>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                
                <Rectangle Height="15"/> <!-- Разделитель между элементами -->
                
                <StackPanel Orientation="Horizontal">
                    <TextBlock>
                        Введите кол-во разбиений:
                    </TextBlock>
                    <TextBox x:Name = "PartitionAmount" Width="100" Margin="5, 0, 0, 0">
                    </TextBox>
                </StackPanel>

                <Rectangle Height="15"/> <!-- Разделитель между элементами -->

                <StackPanel x:Name = "PorePanel" >
                    <TextBlock>Вид распределение пор:</TextBlock>
                    <RadioButton GroupName="Pores" Content="По количеству" IsChecked="True" />
                    <RadioButton GroupName="Pores" Content="По процентному соотношению" />
                </StackPanel>
                
                <StackPanel Orientation="Horizontal">
                    <TextBlock>
                        Значение:
                    </TextBlock>
                    <TextBox x:Name = "PoresValue" Width="196" Margin="5, 0, 0, 0">
                    </TextBox>
                </StackPanel>

                <Rectangle Height="10"/>

                <CheckBox x:Name="ColorComponentsCheckBox"
                          Checked="OnColorByComponentChanged"
                          Unchecked="OnColorByComponentChanged"
                          HorizontalContentAlignment="Left">
                    <TextBlock Text="Показывать связные участки разными цветами"
                               TextWrapping="Wrap"
                               MaxWidth="230"/>
                </CheckBox>

                <Rectangle Height="5"/>

                <CheckBox x:Name="PreserveMaterialCheckBox"
                          HorizontalContentAlignment="Left">
                    <TextBlock Text="Сохранять количество материала при соединении"
                               TextWrapping="Wrap"
                               MaxWidth="230"/>
                </CheckBox>

                <Rectangle Height="5"/>

                <CheckBox x:Name="ShowPercolationCheckBox"
                          IsEnabled="False"
                          Checked="OnShowPercolationChanged"
                          Unchecked="OnShowPercolationChanged"
                          HorizontalContentAlignment="Left">
                    <TextBlock Text="Просмотр деревьев перколяции"
                               TextWrapping="Wrap"
                               MaxWidth="230"/>
                </CheckBox>

                <Rectangle Height="5"/>

                <TextBlock Text="Дерево перколяции:"/>
                <ComboBox x:Name="PercolationTreeSelector"
                          IsEnabled="False"
                          SelectionChanged="OnPercolationTreeSelectionChanged"/>
            </StackPanel>
        </Grid>
        
        <WrapPanel  Grid.Column="1" Grid.Row="1"  Margin="10">
            <Button 
                Content = "Сгенерировать объект"  
                Click = "OnMethodSelected" 
                Margin="5" 
                Width="120" 
                Height="30" 
                VerticalAlignment="Bottom">
            </Button>

            <Button
                x:Name="CheckCoherencyButton"
                Content = "Проверка на связность"
                Click = "OnCheckCoherency"
                Margin="5"
                Width="120"
                Height="30"
                VerticalAlignment="Bottom">
            </Button>

            <Button
                x:Name="ConnectComponentsButton"
                Content = "Соединить компоненты"
                Click = "OnConnectComponents"
                Margin="5"
                Width="120"
                Height="30"
                VerticalAlignment="Bottom">
            </Button>

            <Button
                Content = "Проверка на перколяцию"
                Click = "OnCheckPercolation"
                Margin="5" 
                Width="120" 
                Height="30" 
                VerticalAlignment="Bottom">
            </Button>
        </WrapPanel>
    </Grid>
</Window>
